# --- Google Drive (mtg-importer) ---
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/google-drive.json
GOOGLE_DRIVE_TRANSCRIPT_FOLDER_ID=

# --- Vault path ---
VAULT_PATH=./vault

# --- Organization info (used by mtg-importer & classifier) ---
# Comma-separated. Used to detect own/related orgs in transcript filenames & content.
YOUR_EMAIL_DOMAINS=example.com
YOUR_ORGANIZATIONS=Acme Inc

# --- Notification sink ---
# One of: discord | slack | stdout | file
NOTIFICATION_SINK=stdout
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
NOTIFICATION_FILE_PATH=./logs/notifications.log
